# Dummy values so importing src/lib/supabase.ts doesn't throw during tests
# (Vite loads .env.test automatically when Vitest runs in "test" mode).
# No real secret here — the Supabase client is never actually called in
# tests; components that need auth state mock ../lib/supabase directly.
VITE_SUPABASE_URL=https://test.supabase.invalid
VITE_SUPABASE_ANON_KEY=test-anon-key
